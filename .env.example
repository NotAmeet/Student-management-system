.env.example
# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///student_management.db
# For PostgreSQL: postgresql://user:password@localhost/student_db
# For MySQL: mysql://user:password@localhost/student_db

# Application Settings
DEBUG=True
TESTING=False

# Server Configuration
HOST=0.0.0.0
PORT=5000
